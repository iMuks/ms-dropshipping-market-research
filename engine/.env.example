# Copy this file to .env and fill in your keys.
# Never commit .env — it's in .gitignore.

# --- Anthropic (Claude Agent SDK) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Langfuse (self-hosted, default docker compose ports) ---
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...

# --- DataForSEO (optional in v0; only used if WebSearch is insufficient) ---
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# --- Reddit (PRAW, read-only) ---
# Create a "script" type app at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=niche-research/0.1 by your_reddit_username

# --- Apify (marketplace scrapers: Temu, Shein, AliExpress, fallback Amazon) ---
# Sign up at apify.com; actors are pay-per-run, ~$0.25–$1 per scrape
APIFY_TOKEN=
# Actor IDs to use (configurable per platform)
APIFY_ACTOR_AMAZON=junglee~amazon-crawler
APIFY_ACTOR_TEMU=epctex~temu-scraper
APIFY_ACTOR_SHEIN=epctex~shein-scraper
APIFY_ACTOR_ALIEXPRESS=epctex~aliexpress-scraper

# --- Engine config ---
COST_CAP_USD_PER_BRIEF=5.0
ORCHESTRATOR_MODEL=claude-opus-4-7
SPECIALIST_MODEL=claude-sonnet-4-6
REVIEWER_MODEL=claude-opus-4-7
